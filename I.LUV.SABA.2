<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>Message</title>
<style>
    body {
        margin: 0;
        overflow: hidden;
        font-family: Arial, sans-serif;
        background: #2b0008;
    }

    /* القلوب */
    .hearts {
        position: fixed;
        width: 100%;
        height: 100%;
        z-index: -2;
    }

    .heart {
        position: absolute;
        width: 18px;
        height: 18px;
        background: rgba(255, 120, 140, 0.4);
        transform: rotate(45deg);
        animation: float 14s linear infinite;
    }

    .heart::before,
    .heart::after {
        content: "";
        position: absolute;
        width: 18px;
        height: 18px;
        background: inherit;
        border-radius: 50%;
    }

    .heart::before { top: -9px; left: 0; }
    .heart::after { left: -9px; top: 0; }

    @keyframes float {
        0% {
            transform: translateY(100vh) translateX(0) rotate(45deg);
            opacity: 0;
        }
        50% {
            transform: translateY(40vh) translateX(5px) rotate(45deg);
            opacity: 0.7;
        }
        100% {
            transform: translateY(-10vh) translateX(-5px) rotate(45deg);
            opacity: 0;
        }
    }

    /* الضبابية */
    .overlay {
        position: fixed;
        width: 100%;
        height: 100%;
        background: rgba(40, 0, 10, 0.6);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: -1;
    }

    /* القالب */
    .container {
        position: relative;
        z-index: 1;
        width: 340px;
        margin: 150px auto;
        padding: 25px;
        border-radius: 20px;
        background: #5a0015;
        text-align: center;
        box-shadow: 0 0 30px rgba(255, 100, 180, 0.7);
    }

    .message {
        color: #fff;
        font-size: 18px;
        opacity: 0;
        transform: scale(0.9);
        transition: 1s ease;
    }

    .message.show {
        opacity: 1;
        transform: scale(1);
    }

</style>
</head>
<body>

<div class="hearts" id="hearts"></div>
<div class="overlay"></div>

<div class="container">
    <div id="msg" class="message">
        انت اهم شخص في حياتي ❤️  
        و وجودك يخليني مبسوط دايمًا 💖
    </div>
</div>

<script>
    const heartsContainer = document.getElementById("hearts");

    for (let i = 0; i < 25; i++) {
        let heart = document.createElement("div");
        heart.classList.add("heart");

        heart.style.left = Math.random() * 100 + "vw";
        heart.style.animationDuration = (10 + Math.random() * 5) + "s";
        heart.style.opacity = Math.random();

        heartsContainer.appendChild(heart);
    }

    // ظهور النص
    setTimeout(() => {
        document.getElementById("msg").classList.add("show");
    }, 500);
</script>

</body>
</html>
